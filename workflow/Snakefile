checkpoint get_trait_file:
    input:
        traitData = config["traitData"]
    output:
        traitFile = "results/{trait}/{trait}_data.tsv"
    conda:
        "envs/allEnv.yml"
    shell:
        r"""
        mkdir -p results/{wildcards.trait}
        : > {output.traitFile}

        sed -n '1p' {input.traitData} | tr "\t" "\n" > results/{wildcards.trait}/er1
        echo -e 'Unique.ID' | cat - results/{wildcards.trait}/er1 > results/{wildcards.trait}/er2

        grep -w {wildcards.trait} {input.traitData} | \
        tr "\t" "\n" | \
        paste results/{wildcards.trait}/er2 - > {output.traitFile}
        rm results/{wildcards.trait}/er1 results/{wildcards.trait}/er2
        """
