from snakemake.utils import min_version
min_version("8.0")

import pandas as pd
from functools import lru_cache
from pathlib import Path

configfile: "path/to/config.yaml"

trait_matrix_path = config["traitData"]
traits = pd.read_csv(trait_matrix_path, sep="\t", index_col=0).index.tolist()
chromosomes = [str(c) for c in range(1,23)]

rule all:
    input:
        expand("results/{trait}/{trait}_chr{chromosome}_LMM.assoc.txt", trait = traits, chromosome = chromosomes)
include: "rules/getAnalysisFiles.smk"
include: "rules/GEMMA_analysis.smk"

